<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    x:Class="AppInventario.Views.LoginPage"
    Title="Login">

    <VerticalStackLayout
        Padding="30"
        Spacing="20"
        VerticalOptions="Center">

        <Label
            Text="Sistema de Inventario"
            FontSize="28"
            FontAttributes="Bold"
            HorizontalOptions="Center"/>

        <Entry
            Placeholder="Usuario"/>

        <Entry
            Placeholder="Contraseña"
            IsPassword="True"/>

        <Button
            Text="Iniciar Sesión"/>

    </VerticalStackLayout>

</ContentPage>