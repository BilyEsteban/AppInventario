<?xml version="1.0" encoding="UTF-8" ?>
    <ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    x:Class="AppInventario.Views.ProductFormPage"
    Title="Producto">

    <ScrollView>

        <VerticalStackLayout
            Padding="20"
            Spacing="15">

            <Entry Placeholder="Código"/>

            <Entry Placeholder="Nombre"/>

            <Editor
                Placeholder="Descripción"
                HeightRequest="120"/>

            <Entry
                Placeholder="Precio Compra"
                Keyboard="Numeric"/>

            <Entry
                Placeholder="Precio Venta"
                Keyboard="Numeric"/>

            <Entry
                Placeholder="Stock Inicial"
                Keyboard="Numeric"/>

            <Button
                Text="Guardar"/>

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>