            <!-- Contenido Principal -->
            <VerticalStackLayout Padding="20" Spacing="16">
                
                <Label
                    Text="Bienvenido"
                    FontSize="30"
                    FontAttributes="Bold"
                    TextColor="#1F2937"/>

                <!-- Tarjeta de Productos -->
                <Frame BorderColor="#E5E7EB" CornerRadius="12" Padding="16" BackgroundColor="White" HasShadow="False">
                    <HorizontalStackLayout Spacing="40">
                        <VerticalStackLayout Spacing="15">                            
                            <Label Text="Productos" FontSize="14" TextColor="#6B7280" FontAttributes="Bold"/>
                            <Label Text="125" FontSize="32" TextColor="#3B82F6" FontAttributes="Bold"/>
                        </VerticalStackLayout> 
                        
                        <VerticalStackLayout Spacing="15">                            
                            <Label Text="Bajo Stock" FontSize="14" TextColor="#6B7280" FontAttributes="Bold"/>
                            <Label Text="125" FontSize="32" TextColor="#3B82F6" FontAttributes="Bold"/>
                        </VerticalStackLayout>  
                        
                        <VerticalStackLayout Spacing="15">                            
                            <Label Text="Productos" FontSize="14" TextColor="#6B7280" FontAttributes="Bold"/>
                            <Label Text="125" FontSize="32" TextColor="#3B82F6" FontAttributes="Bold"/>
                        </VerticalStackLayout>                        
                    </HorizontalStackLayout>
                </Frame>

                <!-- Acciones Rápidas -->
                <Label 
                    Text="Acciones Rápidas" 
                    FontSize="18"
                    FontAttributes="Bold"
                    TextColor="#1F2937"/>

                <Grid ColumnDefinitions="*,*" RowSpacing="12" ColumnSpacing="12">
                    
                    <!-- Botón Productos -->
                    <Button 
                        Text="Ver Productos" 
                        BackgroundColor="#3B82F6"
                        TextColor="White"
                        FontAttributes="Bold"
                        CornerRadius="10"
                        Padding="16,20"
                        FontSize="14"
                        Grid.Column="1"
                        Clicked="OnProductsClicked"/>
                    
                    <!-- Botón Reportes -->
                    <Button 
                        Text="Reportes" 
                        BackgroundColor="#F59E0B"
                        TextColor="White"
                        FontAttributes="Bold"
                        CornerRadius="10"
                        Padding="16,20"
                        FontSize="14"
                        Grid.Row="1"
                        Clicked="OnProductsClicked"/>                   

                </Grid>

                <!-- Últimos Movimientos -->
                <Label 
                    Text="Últimos Movimientos" 
                    FontSize="18"
                    FontAttributes="Bold"
                    TextColor="#1F2937"
                    Margin="0,8,0,0"/>

                <VerticalStackLayout Spacing="8">
                    
                    <!-- Movimiento 1 -->
                    <Frame BorderColor="#E5E7EB" CornerRadius="10" Padding="14" HasShadow="False" BackgroundColor="White">
                        <Grid ColumnDefinitions="50,*,Auto" ColumnSpacing="12" RowSpacing="4">
                            <Label 
                                Text="📦" 
                                FontSize="28"
                                VerticalOptions="Center"/>
                            <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                <Label 
                                    Text="Entrada de Stock" 
                                    FontSize="14"
                                    FontAttributes="Bold"
                                    TextColor="#1F2937"/>
                                <Label 
                                    Text="Producto: Tornillos M4 - 500 unidades" 
                                    FontSize="12"
                                    TextColor="#6B7280"/>
                            </VerticalStackLayout>
                            <Label 
                                Text="Hace 2h" 
                                FontSize="12"
                                TextColor="#9CA3AF"
                                Grid.Column="2"
                                VerticalOptions="Center"/>
                        </Grid>
                    </Frame>

                    <!-- Movimiento 2 -->
                    <Frame BorderColor="#E5E7EB" CornerRadius="10" Padding="14" HasShadow="False" BackgroundColor="White">
                        <Grid ColumnDefinitions="50,*,Auto" ColumnSpacing="12" RowSpacing="4">
                            <Label 
                                Text="" 
                                FontSize="28"
                                VerticalOptions="Center"/>
                            <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                <Label 
                                    Text="Salida de Stock" 
                                    FontSize="14"
                                    FontAttributes="Bold"
                                    TextColor="#1F2937"/>
                                <Label 
                                    Text="Producto: Arandelas - 200 unidades" 
                                    FontSize="12"
                                    TextColor="#6B7280"/>
                            </VerticalStackLayout>
                            <Label 
                                Text="Hace 5h" 
                                FontSize="12"
                                TextColor="#9CA3AF"
                                Grid.Column="2"
                                VerticalOptions="Center"/>
                        </Grid>
                    </Frame>

            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>